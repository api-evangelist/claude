              },
              {
                "name": "anthropic-beta",
                "value": ""
              }
            ],
            "params": [
              {
                "name": "model_id",
                "value": "claude-sonnet-4-6",
                "type": "path",
                "description": "The unique identifier of the model to retrieve."
              }
            ]
          },
          "docs": "Retrieve metadata for a specific Claude model by its ID."
        }
      ]
    }
  ],
  "bundled": true
}